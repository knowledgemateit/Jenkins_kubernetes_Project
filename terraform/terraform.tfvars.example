# Copy this file to terraform.tfvars and edit the values for your setup.
# terraform.tfvars is gitignored.

aws_region    = "us-east-1"
project_name  = "jenkins-k8s"
instance_type = "t3.medium"

# Path to the SSH PUBLIC key (.pub) on the DEPLOY EC2.
# scripts/setup-deploy-server.sh creates this for you at ~/.ssh/jenkins_k8s_key.pub
# (~ is expanded by terraform via pathexpand(), so either form works.)
public_key_path = "~/.ssh/jenkins_k8s_key.pub"
key_name        = "jenkins-k8s-key"

# Lock these down to your IP for security. NOTE: must include the deploy EC2's
# public IP, otherwise the deploy server cannot SSH/kubectl-into the new EC2s.
# Quick recipe (run on the deploy EC2):
#   MY_IP=$(curl -s ifconfig.me)/32
#   echo "ssh_ingress_cidr = \"$MY_IP\""
ssh_ingress_cidr      = "0.0.0.0/0"
jenkins_ingress_cidr  = "0.0.0.0/0"
nodeport_ingress_cidr = "0.0.0.0/0"

root_volume_size_gb = 20
